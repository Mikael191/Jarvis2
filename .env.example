# ===================================================
# JARVIS - Environment Variables
# Copy this file to .env and fill in your values.
# ===================================================

# ── REQUIRED ───────────────────────────────────────
# Get a free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── WAKE WORD (optional — falls back to text mode) ─
# Get a free key at: https://console.picovoice.ai
PICOVOICE_ACCESS_KEY=
# Path to a custom .ppn file (leave blank to use built-in "jarvis")
WAKE_WORD_PATH=

# ── LLM SETTINGS ───────────────────────────────────
# Options: llama-3.3-70b-versatile | llama-3.1-8b-instant (faster, smaller)
GROQ_MODEL=llama-3.3-70b-versatile

# ── TTS SETTINGS ───────────────────────────────────
# Run: python -c "import asyncio; import edge_tts; asyncio.run(edge_tts.list_voices())"
# to see all available voices.
TTS_VOICE=pt-BR-AntonioNeural
# Speed: +10% = slightly faster, -10% = slower
TTS_SPEED=+10%

# ── MEMORY SETTINGS ────────────────────────────────
MEMORY_MAX_TURNS=20
MEMORY_MAX_MINUTES=60

# ── AUDIO SETTINGS ─────────────────────────────────
AUDIO_SAMPLE_RATE=16000
RECORD_SILENCE_TIMEOUT=2.5

# ── INTEGRATIONS (optional) ────────────────────────
# Get a free key at: https://openweathermap.org/api
# Without this, weather queries fall back to DuckDuckGo search.
OPENWEATHERMAP_API_KEY=

# Gemini - Usado para o Jarvis enxergar a tela do computador (Vision)
# Pegue a chave grátis (1.500 requisições/dia) em: https://aistudio.google.com/
GEMINI_API_KEY=
